generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  PROVIDER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  REQUIRES_PAYMENT
  SUCCEEDED
  FAILED
  REFUNDED
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  role      Role      @default(CUSTOMER)
  provider  Provider?
  bookings  Booking[]
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
}

model Provider {
  id          String                  @id @default(cuid())
  userId      String                  @unique
  user        User                    @relation(fields: [userId], references: [id])
  displayName String
  slug        String                  @unique
  timezone    String
  services    Service[]
  resources   Resource[]
  rules       AvailabilityRule[]
  exceptions  AvailabilityException[]
  bookings    Booking[]
  createdAt   DateTime                @default(now()) @db.Timestamptz(3)
}

model Resource {
  id         String        @id @default(cuid())
  providerId String
  provider   Provider      @relation(fields: [providerId], references: [id])
  name       String                 // e.g. "Room 1", "Chair A", "Seat 14F"
  units      BookingUnit[]
  createdAt  DateTime      @default(now()) @db.Timestamptz(3)

  @@index([providerId])
}

model Service {
  id              String    @id @default(cuid())
  providerId      String
  provider        Provider  @relation(fields: [providerId], references: [id])
  name            String
  durationMinutes Int
  priceCents      Int
  depositCents    Int       @default(0)
  bookings        Booking[]
  createdAt       DateTime  @default(now()) @db.Timestamptz(3)
}

model AvailabilityRule {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  @@index([providerId])
}

model AvailabilityException {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  startTime  DateTime @db.Timestamptz(3)
  endTime    DateTime @db.Timestamptz(3)
  reason     String?
  createdAt  DateTime @default(now()) @db.Timestamptz(3)

  @@index([providerId])
}

model Booking {
  id            String        @id @default(cuid())
  providerId    String
  provider      Provider      @relation(fields: [providerId], references: [id])
  serviceId     String
  service       Service       @relation(fields: [serviceId], references: [id])
  customerId    String
  customer      User          @relation(fields: [customerId], references: [id])
  startTime     DateTime      @db.Timestamptz(3)
  endTime       DateTime      @db.Timestamptz(3)
  status        BookingStatus @default(PENDING)
  holdExpiresAt DateTime?     @db.Timestamptz(3)   // for the seat-lock / hold expiry (Day 22)
  units         BookingUnit[]
  payment       Payment?
  createdAt     DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime      @updatedAt @db.Timestamptz(3)

  @@index([providerId, startTime])
  @@index([customerId])
}

model BookingUnit {
  id         String        @id @default(cuid())
  bookingId  String
  booking    Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  resourceId String
  resource   Resource      @relation(fields: [resourceId], references: [id])
  startTime  DateTime      @db.Timestamptz(3)      // denormalized so the DB constraint is self-contained
  endTime    DateTime      @db.Timestamptz(3)
  status     BookingStatus @default(PENDING)       // mirrors the order; the EXCLUDE constraint reads this
  createdAt  DateTime      @default(now()) @db.Timestamptz(3)

  @@index([bookingId])
  @@index([resourceId, startTime])
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @unique
  booking               Booking       @relation(fields: [bookingId], references: [id])
  stripePaymentIntentId String?       @unique
  amountCents           Int
  currency              String        @default("usd")
  status                PaymentStatus @default(REQUIRES_PAYMENT)
  createdAt             DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime      @updatedAt @db.Timestamptz(3)
}

model WebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  receivedAt    DateTime @default(now()) @db.Timestamptz(3)
}